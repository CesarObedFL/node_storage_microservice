{
  "name": "node_storage_microservice",
  "version": "1.2.0",
  "description": "Generic microservice built in Node.js to store JSON files with information relevant to projects; an attempt at database emulation.",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NO_COLOR=1 vitest --run --reporter=verbose 2>&1 | tee tests/test.txt",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop storage-microservice",
    "pm2:restart": "pm2 restart storage-microservice",
    "pm2:reload": "pm2 reload storage-microservice",
    "pm2:delete": "pm2 delete storage-microservice",
    "pm2:logs": "pm2 logs storage-microservice",
    "pm2:status": "pm2 status"
  },
  "keywords": [],
  "author": "CesarObedFL",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "pm2": "^7.0.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
