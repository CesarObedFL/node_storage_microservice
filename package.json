{
  "name": "node_storage_microservice",
  "version": "1.2.0",
  "description": "Generic microservice built in Node.js to store JSON files with information relevant to projects; an attempt at database emulation.",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NO_COLOR=1 vitest --run --reporter=verbose 2>&1 | tee tests/test.txt",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [],
  "author": "CesarObedFL",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
